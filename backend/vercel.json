{
  "version": 2,
  "builds": [
    {
      "src": "backend/app/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "backend/app/main.py",
      "dest": "/api"
    }
  ],
  "env": {
    "DATABASE_URL": "@sqlite_db",
    "GROQ_API_KEY": "@groq_api_key",
    "SECRET_KEY": "@secret_key",
    "RESEND_API_KEY": "@resend_api_key"
  }
}
